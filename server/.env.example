# ── Servidor ──────────────────────────────────────────────
PORT=3000
# NODE_ENV: development | production | test
NODE_ENV=development

# ── Base de datos ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vet

# ── JWT ───────────────────────────────────────────────────
# IMPORTANTE: cambiar JWT_SECRET por una cadena aleatoria larga en produccion
# Ejemplo: openssl rand -base64 64
JWT_SECRET=petcare_dev_secret_cambiar_en_produccion
JWT_EXPIRES_IN=24h

# ── Refresh Tokens ────────────────────────────────────────
# Dias de validez del refresh token (default: 7)
REFRESH_TOKEN_EXPIRY_DAYS=7

# ── CORS ──────────────────────────────────────────────────
# Origins permitidos, separados por coma (sin espacios entre URLs)
# En produccion reemplazar con la URL real del frontend
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Logging ──────────────────────────────────────────────
# Niveles: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=debug

# ── MercadoPago ───────────────────────────────────────────
# Obtener credenciales en https://www.mercadopago.com.ar/developers/panel
# Para sandbox: usar Access Token de prueba (comienza con TEST-)
MP_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# URL pública del backend (necesaria para el webhook de MP)
BACKEND_URL=http://localhost:3000
# URL pública del frontend (para los back_urls de MP)
FRONTEND_URL=http://localhost:5173

# ══════════════════════════════════════════════════════════
# PRODUCCION — Copiar a .env y ajustar valores
# ══════════════════════════════════════════════════════════
# NODE_ENV=production
# PORT=3000
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/petcare?retryWrites=true&w=majority
# JWT_SECRET=<generar con: openssl rand -base64 64>
# JWT_EXPIRES_IN=15m
# REFRESH_TOKEN_EXPIRY_DAYS=7
# CORS_ORIGINS=https://tudominio.com
# LOG_LEVEL=warn
