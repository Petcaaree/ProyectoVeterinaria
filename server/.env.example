# ── Servidor ──────────────────────────────────────────────
PORT=3000

# ── Base de datos ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vet

# ── JWT ───────────────────────────────────────────────────
# IMPORTANTE: cambiar JWT_SECRET por una cadena aleatoria larga en produccion
# Ejemplo: openssl rand -base64 64
JWT_SECRET=petcare_dev_secret_cambiar_en_produccion
JWT_EXPIRES_IN=24h

# ── CORS ──────────────────────────────────────────────────
# Origins permitidos, separados por coma (sin espacios entre URLs)
# En produccion reemplazar con la URL real del frontend
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
